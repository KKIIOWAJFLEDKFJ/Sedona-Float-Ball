<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_marginBottom="8dp"
            android:text="释放轨迹"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.prolificinteractive.materialcalendarview.MaterialCalendarView
            android:id="@+id/calendar_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:mcv_calendarMode="month"
            app:mcv_selectionColor="#E8F5E9"
            app:mcv_showOtherDates="all"
            app:mcv_tileHeight="42dp" />

        <TextView
            android:id="@+id/tv_selected_date_stat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:text="点击日期查看细节"
            android:textColor="#999999"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:letterSpacing="0.05"
            android:text="本次释放目标（可不填）"
            android:textColor="#78909C"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/et_release_target"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_input_field"
            android:hint="此刻想放下什么？"
            android:inputType="text"
            android:maxLines="1"
            android:padding="14dp"
            android:textColor="#263238"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:id="@+id/btn_mode_direct"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginRight="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_mode"
                android:lineSpacingExtra="4dp"
                android:text="🚀\n快速"
                android:textColor="#455A64"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_mode_simple"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginRight="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_mode"
                android:lineSpacingExtra="4dp"
                android:text="✨\n简单"
                android:textColor="#455A64"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_mode_complex"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_mode"
                android:lineSpacingExtra="4dp"
                android:text="🌀\n深度"
                android:textColor="#455A64"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="🚀快速:仅识别  ✨简单:三步引导  🌀深度:完整清理"
        android:textColor="#B0BEC5"
        android:textSize="10sp"
        android:alpha="0.8" />

</LinearLayout>